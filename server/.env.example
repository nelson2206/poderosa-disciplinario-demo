ANTHROPIC_API_KEY=sk-ant-...
# Modelo por defecto. Si solo defines éste, se usa para los 3 endpoints.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Override por endpoint (opcional, optimiza costes ~60-80% con Haiku):
# - GENERATOR: redacta cartas. Sonnet ideal.
# - CLASSIFIER: clasifica el tipo. Haiku es suficiente.
# - VISION: extrae datos del DNI. Haiku es suficiente.
# ANTHROPIC_MODEL_GENERATOR=claude-sonnet-4-6
# ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5
# ANTHROPIC_MODEL_VISION=claude-haiku-4-5
PORT=8787
ALLOW_ORIGIN=*
STATIC_DIR=..

# Token de acceso compartido (X-Pod-Token).
# Vacío o "dev" → auth deshabilitado (solo desarrollo local).
# En producción, define una cadena aleatoria larga (32+ chars).
POD_API_TOKEN=

# Storage: si NO defines SUPABASE_* el backend usa filesystem (server/data/).
# Define ambos para activar Postgres + Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Solo aplica al backend filesystem (override del directorio de datos)
# POD_DATA_DIR=/data
