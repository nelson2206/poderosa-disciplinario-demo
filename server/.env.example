OPENAI_API_KEY=sk-proj-...
# Modelo por defecto (API de OpenAI / ChatGPT). Si solo defines éste, se usa
# para los 3 endpoints.
OPENAI_MODEL=gpt-5
# Override por endpoint (opcional, optimiza coste delegando lo liviano):
# - GENERATOR: redacta las cartas disciplinarias. gpt-5 (razonamiento) es el ideal.
#   Alternativa más rápida/barata si no necesitas razonamiento: gpt-4.1
# - CLASSIFIER: clasifica el tipo de carta. gpt-5-mini es suficiente.
# - VISION: extrae datos del DNI/ficha (necesita visión). gpt-4o es sólido y económico.
# OPENAI_MODEL_GENERATOR=gpt-5
# OPENAI_MODEL_CLASSIFIER=gpt-5-mini
# OPENAI_MODEL_VISION=gpt-4o
# Esfuerzo de razonamiento del generador (solo modelos gpt-5 / o*): minimal|low|medium|high
# OPENAI_REASONING_EFFORT=medium
PORT=8787
ALLOW_ORIGIN=*
STATIC_DIR=..

# Token de acceso compartido (X-Pod-Token).
# Vacío o "dev" → auth deshabilitado (solo desarrollo local).
# En producción, define una cadena aleatoria larga (32+ chars).
POD_API_TOKEN=

# Storage: si NO defines SUPABASE_* el backend usa filesystem (server/data/).
# Define ambos para activar Postgres + Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Solo aplica al backend filesystem (override del directorio de datos)
# POD_DATA_DIR=/data

# ── Correo (SMTP) — OPCIONAL ────────────────────────────────────────────────
# Habilita el "envío directo desde la herramienta". Si lo dejas vacío, el
# frontend usa el camino "borrador de Outlook" (.eml) y /api/correos/enviar
# devuelve 503. Ejemplo para Microsoft 365 / Outlook corporativo:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=0           # 0 = STARTTLS (587), 1 = SSL directo (465)
#   SMTP_USER=rrhh@poderosa.com.pe
#   SMTP_PASS=...           # contraseña o app password
#   SMTP_FROM=rrhh@poderosa.com.pe
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Organigrama ─────────────────────────────────────────────────────────────
# El directorio de empleados (jefe directo + correos) vive en un bucket privado
# de Supabase (bucket "org", objeto organigrama.json). Súbelo una vez con:
#   node --env-file=.env scripts/seed-organigrama.mjs
# En dev, si no hay Supabase, el backend lee server/data/organigrama.json (gitignored).
