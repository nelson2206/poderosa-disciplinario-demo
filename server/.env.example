ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=8787
ALLOW_ORIGIN=*
STATIC_DIR=..

# Token de acceso compartido (X-Pod-Token).
# Vacío o "dev" → auth deshabilitado (solo desarrollo local).
# En producción, define una cadena aleatoria larga (32+ chars).
POD_API_TOKEN=

# Storage: si NO defines SUPABASE_* el backend usa filesystem (server/data/).
# Define ambos para activar Postgres + Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Solo aplica al backend filesystem (override del directorio de datos)
# POD_DATA_DIR=/data
